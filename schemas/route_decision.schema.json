{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-u.dev/schemas/route-decision-v1.json",
  "title": "NEXUS-U Obligation Route Decision",
  "type": "object",
  "required": ["obligation_id", "obligation_signature", "selected", "scores", "escalation_required"],
  "properties": {
    "obligation_id": {"type": "string", "minLength": 1},
    "obligation_signature": {"type": "string", "minLength": 1},
    "selected": {"type": "string"},
    "scores": {"type": "array", "minItems": 1},
    "escalation_required": {"type": "boolean"},
    "escalation_reason": {"type": ["string", "null"]},
    "policy_version": {"type": "string"}
  },
  "additionalProperties": true
}
