{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-u.local/schemas/task.schema.json",
  "title": "NEXUS-U Task",
  "type": "object",
  "required": [
    "intent",
    "artifact_type",
    "modes"
  ],
  "properties": {
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "enum": [
        "theorem",
        "software",
        "model",
        "simulation",
        "policy",
        "experiment",
        "architecture",
        "document",
        "creative_work"
      ]
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "adapter": {
      "type": "string"
    },
    "success_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prohibited_shortcuts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "object"
    },
    "budget": {
      "type": "object",
      "properties": {
        "wall_clock_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "memory_mb": {
          "type": "integer",
          "minimum": 16
        },
        "output_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "external_calls": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "initial_obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "statement"
        ],
        "properties": {
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          },
          "source": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
